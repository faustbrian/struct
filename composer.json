{
    "name": "cline/struct",
    "description": "Lean, attribute-driven Laravel data objects with explicit validation and Eloquent casting support",
    "license": "MIT",
    "keywords": [
        "php"
    ],
    "authors": [
        {
            "name": "Brian Faust",
            "email": "brian@cline.sh"
        }
    ],
    "require": {
        "php": "^8.5.0",
        "cline/attribute-reader": "^1.0",
        "facade/ignition-contracts": "^1.0.2",
        "illuminate/collections": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "illuminate/contracts": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "illuminate/database": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "illuminate/support": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "illuminate/validation": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "spatie/laravel-package-tools": "^1.93.0",
        "spatie/php-structure-discoverer": "^2.4",
        "symfony/yaml": "^7.4.6"
    },
    "require-dev": {
        "beacon-hq/bag": "^2.6.2",
        "cline/bench": "^1.0",
        "cline/coding-standard": "^2.0.1",
        "livewire/livewire": "^4.2.1",
        "orchestra/testbench": "^8.0 || ^9.0 || ^10.9",
        "phpbench/phpbench": "^1.5.1",
        "spatie/laravel-data": "^4.20",
        "symfony/var-dumper": "^6.0 || ^7.4.6"
    },
    "suggest": {
        "livewire/livewire": "Add first-class Livewire Wireable and synthesizer support for data objects."
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Cline\\Struct\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BenchmarksCline\\": "benchmarks-cline/",
            "Benchmarks\\": "benchmarks/",
            "Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "ergebnis/composer-normalize": true,
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "aliases": {
                "Struct": "Cline\\Struct\\Facades\\Struct"
            },
            "providers": [
                "Cline\\Struct\\StructServiceProvider"
            ]
        }
    },
    "scripts": {
        "bench": "vendor/bin/phpbench run benchmarks",
        "bench:cline": "vendor/bin/bench run",
        "bench:cline:compare": "vendor/bin/bench compare --against=snapshot:latest",
        "bench:cline:save": "vendor/bin/bench snapshot:save baseline",
        "bench:compare": "php bin/bench-compare.php",
        "lint": "vendor/bin/ecs check --fix",
        "refactor": "rector",
        "test": [
            "@test:lint",
            "@test:type-coverage",
            "@test:unit",
            "@test:types",
            "@test:refactor"
        ],
        "test:lint": "vendor/bin/ecs check",
        "test:refactor": "rector --dry-run",
        "test:type-coverage": "pest --parallel --min=80 --type-coverage",
        "test:types": "phpstan",
        "test:unit": "pest --parallel --min=80 --coverage"
    }
}
